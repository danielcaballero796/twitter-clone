# --- Postgres (docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Host port the container maps to (change if 5432 is taken on your machine)
POSTGRES_PORT=5432

# --- API (copy to apps/api/.env) ---
API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twitter_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twitter_test

# --- Auth (change 02) ---
# Secret used to sign session JWTs. Use a long random string in real environments.
JWT_SECRET=change-me-in-real-env
# Origin allowed by CORS for credentialed requests from the web app (must be explicit, not a wildcard).
WEB_ORIGIN=http://localhost:5173
